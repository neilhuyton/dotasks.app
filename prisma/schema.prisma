// prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String              @id @default(uuid())
  email                       String              @unique
  password                    String
  verificationToken           String?
  isEmailVerified             Boolean             @default(false)
  resetPasswordToken          String?
  resetPasswordTokenExpiresAt DateTime?
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt

  refreshTokens               RefreshToken[]      
  
  todoLists                   TodoList[]

  @@index([createdAt])
}

model RefreshToken {
  id           String    @id @default(uuid())
  hashedToken  String    @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime? @updatedAt
  expiresAt    DateTime?           // optional – e.g. 90 days

  // future extensions
  // deviceInfo   String?   // "iPhone 16, Safari iOS 18"
  // ipAddress    String?
  // userAgent    String?

  @@index([userId])
  @@index([createdAt])
}

model TodoList {
  id          String    @id @default(uuid())
  title       String
  description String?   
  color       String?   // e.g. "#ef4444" – for nice UI coloring
  icon        String?   // optional emoji or icon name
  isArchived  Boolean   @default(false)
  
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks       Task[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  isCompleted Boolean   @default(false)
  dueDate     DateTime?
  priority    Int?      // 1 = low, 2 = medium, 3 = high (or enum)
  order       Int       @default(0)   // for drag & drop sorting

  listId      String
  list        TodoList  @relation(fields: [listId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([listId])
  @@index([isCompleted])
  @@index([dueDate])
}